# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=gere-uma-chave-segura-com-python-secrets-token-hex-50
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br
DJANGO_CSRF_TRUSTED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
DJANGO_TIME_ZONE=America/Sao_Paulo

# ── Banco de Dados PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=escola_segura
POSTGRES_USER=escola_user
POSTGRES_PASSWORD=senha-forte-aqui
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── E-mail / SMTP ─────────────────────────────────────────────────────────────
# AGENTS_EMAIL_DRY_RUN=true  → e-mails só aparecem no console (modo dev/teste)
# AGENTS_EMAIL_DRY_RUN=false → envio real via SMTP (preencher variáveis abaixo)
AGENTS_EMAIL_DRY_RUN=false

# Remetente padrão dos e-mails gerados pelo Atlas
ATLAS_DEFAULT_FROM_EMAIL=contato@escolasegura360.com.br
DEFAULT_FROM_EMAIL=contato@escolasegura360.com.br

# Credenciais SMTP — Titan Email (recomendado para domínio próprio)
# Alternativas: smtp.gmail.com:587, smtp.sendgrid.net:587
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=587
EMAIL_HOST_USER=contato@escolasegura360.com.br
EMAIL_HOST_PASSWORD=sua-senha-smtp-aqui
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# ── Superusuário Django Admin ─────────────────────────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@escolasegura360.com.br
DJANGO_SUPERUSER_PASSWORD=DefineUmaSenhaForteAqui123!

# ── Usuário de demonstração comercial (/app/) ─────────────────────────────────
DEMO_OWNER_USERNAME=fabrizio
DEMO_OWNER_EMAIL=contato@escolasegura360.com.br
DEMO_OWNER_PASSWORD=EscolaEscolaSegura360!

# Webhook de Leads da Assistente EscolaSegura
SANTANDER_LEAD_WEBHOOK_URL=https://sua-url-de-webhook.com/leads

# ── Segurança (produção) ──────────────────────────────────────────────────────
POLICY_GUARD_STRICT_MODE=true
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
